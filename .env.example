# Public Bitget market data works without any keys.

# Optional: read-only private API for account context in /api/court/evaluate
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
BITGET_READ_ONLY=true

# Public URL when deployed (curl examples on /developers)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional public GetAgent Studio or externally verifiable paper-log URL.
# Shown on /developers only when configured.
PAPER_LOG_URL=
